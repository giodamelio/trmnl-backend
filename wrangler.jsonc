{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "trmnl-backend",
  "main": "src/index.ts",
  "compatibility_date": "2026-05-25",
  "observability": {
    "enabled": true
  }
  // No secrets: the worldcup feed uses ESPN unauthenticated. A future
  // authenticated feed would set its token with `wrangler secret put <NAME>`
  // (or .dev.vars locally) and add it to the Env interface in src/env.ts.
}
