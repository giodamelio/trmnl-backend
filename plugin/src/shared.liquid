{% comment %}
  Shared markup — trmnlp (and TRMNL in production) prepend this file to every
  view before rendering, so the {% template name %}…{% endtemplate %} blocks
  below register reusable partials that each view pulls in with
  {% render 'name', var: value %}. NOTE: {% render %} runs in an ISOLATED scope —
  a partial sees only the variables passed to it, so every input is explicit.

  Partials:
    flag            — one bordered flag, hugging the image at any size
    today_featured  — large current/next game card (size-parameterised)
    today_row       — compact single-line match row (size-parameterised)
    today_column    — the full-height interleaved column of today's games
    section_header  — a section title + horizontal rule
    tomorrow_section / standings_section / favorites_section / city_section
    title_bar       — the bottom bar (logo · competition · date)
{% endcomment %}

{% comment %} ─────────────────────────── flag ───────────────────────────
  One flag image with a 1px frame (flagcdn SVGs are borderless). The border is on
  the <img> so it hugs the flag itself — no letterbox gap — while the wrapping
  <span> holds the fixed h×w box that keeps rows and grids aligned. When src is
  empty (knockout placeholders — a TBD team) it falls back to a generic "?" flag
  so the slot still shows a flag. h/w are CSS lengths ("120px", "1.5em"). Use this
  for EVERY flag so there's one place to change.

  NOTE: at LARGE sizes some flagcdn SVGs (those without a viewBox, e.g. sa.svg) balloon
  past their box in trmnlp's headless-Firefox PNG render — a geckodriver bug; they render
  correctly in real browsers (verify flag-heavy layout in Chrome, not the PNG preview).
  This `flag` partial is used at small sizes (tomorrow/standings/etc.) where it's fine;
  the larger today cards use flag_fit. {% endcomment %}
{% template flag %}
{%- assign flagSrc = src | default: 'data:image/svg+xml;base64,' -%}
<span style="display: inline-flex; align-items: center; justify-content: center; height: {{ h }}; width: {{ w }};"><img class="image" src="{{ flagSrc }}" style="max-height: 100%; max-width: 100%; border: 1px solid; box-sizing: border-box;" /></span>
{% endtemplate %}

{% comment %} ─────────────────────────── flag_fit ───────────────────────────
  Scales to fit its parent cell preserving aspect, with the border HUGGING the flag
  (no letterbox box): max-width/height:100% + width/height:auto sizes the <img> to the
  flag, the border is on that <img>, and the parent's flex alignment (justify/align)
  places it. The parent must bound it (a flex cell with a basis width + stretched
  height). NB this balloons viewBox-less SVGs in headless Firefox (trmnlp preview) but
  renders correctly in real browsers — see memory; verify in Chrome. Used by the today
  cards. {% endcomment %}
{% template flag_fit %}
{%- assign flagSrc = src | default: 'data:image/svg+xml;base64,' -%}
<img class="image" src="{{ flagSrc }}" style="max-width: 100%; max-height: 100%; width: auto; height: auto; border: 1px solid; box-sizing: border-box; display: block;" />
{% endtemplate %}

{% comment %} ─────────────────────────── today_featured ───────────────────────────
  Current / next game — the distinct card: a centred status line on top (LIVE·min /
  FINISHED / Starts·time, + group), a matchup row in the middle, and the venue
  (stadium · city, country) centred on the bottom. Unlike today_row's flag-beside-text,
  each side here stacks a BIG flag on top of name+code (the flag in a flex:1 box that
  takes the height left over above the text — that's what makes the featured visually
  pop vs the rows), with the score/vs centred between. The card is align-items:center
  (so the status/venue lines centre) with the matchup row align-self:stretch (full
  width). `basis` is the card's flex in the column — grow-based (e.g. '2 1 0' ≈ 2× a
  row), never a percentage. Only font-size (`base`) and padding/gaps are fixed. {% endcomment %}
{% template today_featured %}
{%- assign base = base | default: '13px' -%}
{%- assign basis = basis | default: '0 0 50%' -%}
<div style="flex: {{ basis }}; min-height: 0; font-size: {{ base }}; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 0.25em; padding: 5px 8px;">
  <span class="label label--small" style="font-size: 0.85em; text-align: center; flex: 0 0 auto; white-space: nowrap;">{% if m.isLive %}LIVE{% if m.minute %} · {{ m.minute }}'{% endif %}{% elsif m.isFinished %}FINISHED{% else %}Starts {{ m.kickoffLocal }}{% endif %}{% if m.group %} · {{ m.group | replace: "GROUP_", "Group " }}{% endif %}</span>
  <div style="flex: 1 1 0; min-height: 0; align-self: stretch; display: flex; align-items: stretch;">
    <div style="flex: 1 1 0; min-width: 0; display: flex; flex-direction: column; align-items: flex-start; justify-content: center; gap: 0.2em; line-height: 1;">
      <div style="flex: 1 1 0; min-height: 0; width: 100%; display: flex; align-items: center; justify-content: flex-start;">{% render 'flag_fit', src: m.home.crest %}</div>
      <span class="label" style="font-size: 1em; white-space: nowrap;">{{ m.home.name }}</span>
      <span class="value" style="font-size: 2.4em; font-weight: 700; line-height: 1;">{{ m.home.tla }}</span>
    </div>
    <span class="value" style="font-size: 2.6em; font-weight: 700; white-space: nowrap; flex: 0 0 auto; align-self: center; padding: 0 0.4em;">{% if m.isLive or m.isFinished %}{{ m.home.score | default: 0 }}<span style="margin: 0 0.12em;">&ndash;</span>{{ m.away.score | default: 0 }}{% else %}vs{% endif %}</span>
    <div style="flex: 1 1 0; min-width: 0; display: flex; flex-direction: column; align-items: flex-end; justify-content: center; gap: 0.2em; line-height: 1;">
      <div style="flex: 1 1 0; min-height: 0; width: 100%; display: flex; align-items: center; justify-content: flex-end;">{% render 'flag_fit', src: m.away.crest %}</div>
      <span class="label" style="font-size: 1em; white-space: nowrap;">{{ m.away.name }}</span>
      <span class="value" style="font-size: 2.4em; font-weight: 700; line-height: 1;">{{ m.away.tla }}</span>
    </div>
  </div>
  {% if m.venue %}<span class="label label--small" style="font-size: 0.85em; text-align: center; flex: 0 0 auto; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">{{ m.venue.fifaName }} · {{ m.venue.city }}, {{ m.venue.country }}</span>{% endif %}
</div>
{% endtemplate %}

{% comment %} ─────────────────────────── today_row ───────────────────────────
  Other game — one flex row of five cells: flag · name+code · score/time · name+code ·
  flag. Each cell has a flex-basis so the flags are capped at a sensible max width
  (no runaway-wide flags) while still filling the row's height up to that cap; the
  two name+code cells grow to share the leftover width and keep the score centred.
  Root flex:1 1 0 lets stacked rows split the column height. Only font-size (`base`)
  and padding/gaps are fixed. {% endcomment %}
{% template today_row %}
{%- assign base = base | default: '14px' -%}
<div style="flex: 1 1 0; min-height: 0; font-size: {{ base }}; display: flex; align-items: stretch; padding: 5px 7px;">
  <div style="flex: 0 1 28%; min-width: 0; display: flex; align-items: center; justify-content: flex-start;">{% render 'flag_fit', src: m.home.crest %}</div>
  <div style="flex: 1 1 20%; min-width: 0; display: flex; flex-direction: column; align-items: flex-start; justify-content: center; line-height: 1; gap: 0.12em; padding-left: 0.45em; overflow: hidden;">
    <span class="label" style="font-size: 0.95em; white-space: nowrap;">{{ m.home.name }}</span>
    <span class="value" style="font-size: 1.9em; font-weight: 700; white-space: nowrap;">{{ m.home.tla }}</span>
  </div>
  <div style="flex: 0 1 auto; display: flex; flex-direction: column; align-items: center; justify-content: center; line-height: 1; gap: 0.15em; padding: 0 0.4em;">
    {% if m.isLive or m.isFinished %}
      <span class="label label--small" style="font-size: 0.75em;">{% if m.isLive %}LIVE{% if m.minute %} {{ m.minute }}'{% endif %}{% else %}FT{% endif %}</span>
      <span class="value" style="font-size: 1.75em; font-weight: 700; white-space: nowrap;">{{ m.home.score | default: 0 }}<span style="margin: 0 0.14em;">&ndash;</span>{{ m.away.score | default: 0 }}</span>
    {% else %}
      <span class="value" style="font-size: 1.25em; font-weight: 700; white-space: nowrap;">{{ m.kickoffLocal }}</span>
    {% endif %}
  </div>
  <div style="flex: 1 1 20%; min-width: 0; display: flex; flex-direction: column; align-items: flex-end; justify-content: center; line-height: 1; gap: 0.12em; padding-right: 0.45em; overflow: hidden;">
    <span class="label" style="font-size: 0.95em; white-space: nowrap;">{{ m.away.name }}</span>
    <span class="value" style="font-size: 1.9em; font-weight: 700; white-space: nowrap;">{{ m.away.tla }}</span>
  </div>
  <div style="flex: 0 1 28%; min-width: 0; display: flex; align-items: center; justify-content: flex-end;">{% render 'flag_fit', src: m.away.crest %}</div>
</div>
{% endtemplate %}

{% comment %} ─────────────────────────── today_column ───────────────────────────
  Full-height column of today's games in kickoff order: the current/next game is
  the large featured card in its chronological slot, every other game a compact
  row, hairline rules between. Used by the full and half-vertical views.

  Pure flexbox shares the column height: every card uses a grow-based flex (basis 0,
  NOT a percentage basis — a percentage flex-basis collapses to the flag's huge
  intrinsic height when the column height is only "used, not definite"). The featured
  grows 2× a row, so it's roughly a third and scales with the day's game count. Inside
  each card the flags fill the height the flex layout hands them (see flag_fit) — so a
  busy 6-game day and a quiet 2-game day both fill the column with no per-count tuning.
  Only the font-size (`base`) and padding/gaps are fixed. {% endcomment %}
{% template today_column %}
<div class="columns" style="align-self: stretch;">
  <div class="column" style="height: 100%; justify-content: flex-start; gap: 0;">
    {% for m in matches %}
      {% unless forloop.first %}<hr style="border: 0; border-top: 1px solid; margin: 0; width: 100%;" />{% endunless %}
      {% if m.id == current.id %}
        {% render 'today_featured', m: m, basis: '2 1 0', base: '14px' %}
      {% else %}
        {% render 'today_row', m: m, base: '14px' %}
      {% endif %}
    {% endfor %}
  </div>
</div>
{% endtemplate %}

{% comment %} ─────────────────────────── section_header ─────────────────────────── {% endcomment %}
{% template section_header %}
<div style="display: flex; align-items: center; gap: 10px;">
  <span class="title title--small" style="white-space: nowrap;">{{ title }}</span>
  <hr style="flex: 1 1 auto; border: 0; border-top: 1px solid; margin: 0;" />
</div>
{% endtemplate %}

{% comment %} ─────────────────────────── tomorrow_section ───────────────────────────
  Tomorrow's slate as a grid: 2-up for ≤4 games (2×2), 3-up for 5–6 (a 3+2 / 3+3 grid)
  so a busy group-stage day still fits. The 3-up cells are narrower, so the flag/code
  columns, the inter-column gap and the grid gaps all shrink a touch. Capped at 6 (the
  section's vertical budget — it shares the right column with standings/favorites/city);
  the full slate is always in the /v1/worldcup JSON. Each cell: kickoff · city, then the
  two teams (flag · code · name) with a small "vs" between. {% endcomment %}
{% template tomorrow_section %}
{%- assign n = tomorrow | size -%}
{%- if n > 4 -%}
  {%- assign cols = 3 -%}{%- assign cell = '10px' -%}{%- assign gap = '7px 10px' -%}{%- assign tmpl = '1.9em 2.7em 1fr' -%}{%- assign icg = '0.2em' -%}{%- assign fw = '1.9em' -%}{%- assign fh = '1.3em' -%}{%- assign codeFs = '1.35em' -%}
{%- else -%}
  {%- assign cols = 2 -%}{%- assign cell = '11px' -%}{%- assign gap = '10px 16px' -%}{%- assign tmpl = '2.5em 3em 1fr' -%}{%- assign icg = '0.3em' -%}{%- assign fw = '2.2em' -%}{%- assign fh = '1.5em' -%}{%- assign codeFs = '1.5em' -%}
{%- endif -%}
<div style="display: flex; flex-direction: column; gap: 3px;">
  {% render 'section_header', title: 'Tomorrow' %}
  {% if meta.tomorrowCount > 0 %}
    <div style="display: grid; grid-template-columns: repeat({{ cols }}, 1fr); gap: {{ gap }};">
      {% for m in tomorrow limit: 6 %}
        <div style="font-size: {{ cell }}; min-width: 0; display: flex; flex-direction: column; gap: 0.12em; line-height: 1.1; overflow: hidden;">
          <span class="label" style="font-size: 1em; white-space: nowrap;">
            {{ m.kickoffLocal }}{% if m.venue %} · {{ m.venue.city }}{% endif %}
          </span>
          <div style="display: grid; grid-template-columns: {{ tmpl }}; align-items: center; column-gap: {{ icg }}; white-space: nowrap; line-height: 1;">
            <span style="display: flex; align-items: center;">{% render 'flag', src: m.home.crest, h: fh, w: fw %}</span>
            <span class="value" style="font-size: {{ codeFs }}; font-weight: 700; line-height: 1;">{{ m.home.tla }}</span>
            <span class="label" style="font-size: 1em; min-width: 0; padding-left: 0.5em; overflow: hidden; text-overflow: ellipsis;">{{ m.home.name }}</span>
          </div>
          <div style="display: grid; grid-template-columns: {{ tmpl }}; align-items: center; column-gap: {{ icg }}; white-space: nowrap; line-height: 1;">
            <span style="display: flex; align-items: center;">{% render 'flag', src: m.away.crest, h: fh, w: fw %}</span>
            <span class="value" style="font-size: {{ codeFs }}; font-weight: 700; line-height: 1;">{{ m.away.tla }}</span>
            <span class="label" style="font-size: 1em; min-width: 0; padding-left: 0.5em; overflow: hidden; text-overflow: ellipsis;">{{ m.away.name }}</span>
          </div>
        </div>
      {% endfor %}
    </div>
  {% else %}
    <span class="label label--small">No matches tomorrow</span>
  {% endif %}
</div>
{% endtemplate %}

{% comment %} ─────────────────────────── standings_section ───────────────────────────
  12 mini group tables in a 4-column grid. Each team row is its own small grid
  [rank · flag · code · GD · Pts] so the columns line up within a group. {% endcomment %}
{% template standings_section %}
{% if standings.size > 0 %}
  <div style="display: flex; flex-direction: column; gap: 5px;">
    {% render 'section_header', title: 'Standings' %}
    <div style="display: grid; grid-template-columns: repeat(4, 1fr); column-gap: 12px; row-gap: 8px; font-size: 10px;">
      {% for g in standings %}
        <div style="display: flex; flex-direction: column; gap: 2px;">
          <span class="title" style="font-size: 1.3em; white-space: nowrap; line-height: 1; text-decoration: underline; text-underline-offset: 2px;">{{ g.group }}</span>
          {% for r in g.rows %}
            <div style="display: grid; grid-template-columns: 1em 1.6em 1fr 1.7em 1.4em; align-items: center; column-gap: 4px; white-space: nowrap; line-height: 1;">
              <span class="label" style="text-align: center;">{{ r.rank }}</span>
              <span style="display: flex; align-items: center;">{% render 'flag', src: r.crest, h: '1em', w: '1.5em' %}</span>
              <span class="value" style="font-size: 1.3em; font-weight: 700; line-height: 1;">{{ r.tla }}</span>
              <span class="value" style="font-size: 1.3em; font-weight: 700; line-height: 1; text-align: right;">{% if r.gd > 0 %}+{% endif %}{{ r.gd }}</span>
              <span class="value" style="font-size: 1.3em; font-weight: 700; line-height: 1; text-align: right;">{{ r.points }}</span>
            </div>
          {% endfor %}
        </div>
      {% endfor %}
    </div>
  </div>
{% endif %}
{% endtemplate %}

{% comment %} ─────────────────────────── favorites_section ───────────────────────────
  Next game for each favorite team: flag + name grouped per side and pinned to the
  outer edge, vs/score centred, info line (when · group · venue) below. {% endcomment %}
{% template favorites_section %}
{% if favorites.size > 0 %}
  <div style="display: flex; flex-direction: column; gap: 4px;">
    {% render 'section_header', title: 'Favorites' %}
    {% for f in favorites %}
      <div style="font-size: 12px; display: flex; flex-direction: column; gap: 1px; line-height: 1.05;">
        {% if f.hasGame %}
          <div style="display: flex; align-items: center;">
            <div style="flex: 1 1 0; min-width: 0; display: flex; align-items: center; justify-content: flex-start; gap: 0.4em; white-space: nowrap;">
              {% render 'flag', src: f.fav.crest, h: '1.5em', w: '2.1em' %}
              <span class="value" style="font-size: 1.4em; font-weight: 700; line-height: 1;">{{ f.fav.name }}</span>
            </div>
            <span class="label" style="flex: 0 0 auto; font-size: 0.95em; padding: 0 0.5em; white-space: nowrap;">{% if f.isLive %}{{ f.fav.score | default: 0 }}<span style="margin: 0 0.12em;">&ndash;</span>{{ f.opp.score | default: 0 }}{% else %}vs{% endif %}</span>
            <div style="flex: 1 1 0; min-width: 0; display: flex; align-items: center; justify-content: flex-end; gap: 0.4em; white-space: nowrap;">
              <span class="value" style="font-size: 1.4em; font-weight: 700; line-height: 1;">{{ f.opp.name }}</span>
              {% render 'flag', src: f.opp.crest, h: '1.5em', w: '2.1em' %}
            </div>
          </div>
          <div style="display: flex; align-items: baseline; font-size: 10px;">
            <span class="label" style="flex: 1 1 0; min-width: 0; display: flex; justify-content: flex-start; font-size: 1em; white-space: nowrap;">{% if f.isLive %}LIVE{% if f.minute %} {{ f.minute }}'{% endif %}{% else %}{{ f.when }} {{ f.kickoffLocal }}{% endif %}</span>
            <span class="label" style="flex: 0 0 auto; font-size: 1em; text-align: center; padding: 0 0.5em; white-space: nowrap;">{% if f.group %}{{ f.group }}{% endif %}</span>
            <span class="label" style="flex: 1 1 0; min-width: 0; display: flex; justify-content: flex-end; font-size: 1em; white-space: nowrap;">{% if f.venue %}{{ f.venue.fifaName }}{% endif %}</span>
          </div>
        {% else %}
          <span class="label">{{ f.team }} · no upcoming game</span>
        {% endif %}
      </div>
    {% endfor %}
  </div>
{% endif %}
{% endtemplate %}

{% comment %} ─────────────────────────── city_section ───────────────────────────
  Next games in the viewer's chosen host city — same matchup row shape as
  favorites. {% endcomment %}
{% template city_section %}
{% if cityGames.size > 0 %}
  <div style="display: flex; flex-direction: column; gap: 3px;">
    {% assign cityTitle = city | prepend: 'In ' %}{% render 'section_header', title: cityTitle %}
    {% for sg in cityGames %}
      <div style="font-size: 12px; display: flex; flex-direction: column; gap: 1px; line-height: 1.05;">
        <div style="display: flex; align-items: center;">
          <div style="flex: 1 1 0; min-width: 0; display: flex; align-items: center; justify-content: flex-start; gap: 0.4em; white-space: nowrap;">
            {% render 'flag', src: sg.home.crest, h: '1.5em', w: '2.1em' %}
            <span class="value" style="font-size: 1.4em; font-weight: 700; line-height: 1;">{{ sg.home.name }}</span>
          </div>
          <span class="label" style="flex: 0 0 auto; font-size: 0.95em; padding: 0 0.5em; white-space: nowrap;">{% if sg.isLive %}{{ sg.home.score | default: 0 }}<span style="margin: 0 0.12em;">&ndash;</span>{{ sg.away.score | default: 0 }}{% else %}vs{% endif %}</span>
          <div style="flex: 1 1 0; min-width: 0; display: flex; align-items: center; justify-content: flex-end; gap: 0.4em; white-space: nowrap;">
            <span class="value" style="font-size: 1.4em; font-weight: 700; line-height: 1;">{{ sg.away.name }}</span>
            {% render 'flag', src: sg.away.crest, h: '1.5em', w: '2.1em' %}
          </div>
        </div>
        <div style="display: flex; align-items: baseline; font-size: 10px;">
          <span class="label" style="flex: 1 1 0; min-width: 0; display: flex; justify-content: flex-start; font-size: 1em; white-space: nowrap;">{% if sg.isLive %}LIVE{% if sg.minute %} {{ sg.minute }}'{% endif %}{% else %}{{ sg.when }} {{ sg.kickoffLocal }}{% endif %}</span>
          <span class="label" style="flex: 0 0 auto; font-size: 1em; text-align: center; padding: 0 0.5em; white-space: nowrap;">{% if sg.group %}{{ sg.group }}{% endif %}</span>
          <span class="label" style="flex: 1 1 0; min-width: 0; display: flex; justify-content: flex-end; font-size: 1em; white-space: nowrap;">{% if sg.venue %}{{ sg.venue.fifaName }}{% endif %}</span>
        </div>
      </div>
    {% endfor %}
  </div>
{% endif %}
{% endtemplate %}

{% comment %} The knockout bracket is no longer a CSS partial — it's a server-rendered
  SVG (own route, src/features/worldcup.ts → bracketSvg) embedded by full.liquid via
  an <iframe> (an <img>-embedded SVG can't load its hotlinked flags). {% endcomment %}

{% comment %} ─────────────────────────── title_bar ─────────────────────────── {% endcomment %}
{% template title_bar %}
<div class="title_bar">
  <img class="image" src="https://usetrmnl.com/images/plugins/trmnl--render.svg" />
  <span class="title">{{ meta.competition }}</span>
  <span class="instance">{{ meta.localDate }}</span>
</div>
{% endtemplate %}
