{% comment %} World Cup — half-horizontal view (wide, short). Same content as the
  full view's left column, rearranged: the current/next game fills the left half at
  full height, every other game of the day stacks as compact rows on the right. {% endcomment %}
<div class="layout">
  {% if meta.todayCount > 0 %}
    <div class="columns" style="align-self: stretch;">
      {% comment %} Left — current/next game, full height {% endcomment %}
      <div class="column" style="flex: 1 1 0; height: 100%;">
        {% render 'today_featured', m: current, basis: '1 1 0' %}
      </div>
      {% comment %} Right — the rest of today's games, compact rows {% endcomment %}
      <div class="column" style="flex: 1 1 0; height: 100%; justify-content: flex-start; gap: 0;">
        {% assign firstOther = true %}
        {% for m in matches %}{% unless m.id == current.id %}
          {% unless firstOther %}<hr style="border: 0; border-top: 1px solid; margin: 0; width: 100%;" />{% endunless %}
          {% render 'today_row', m: m %}
          {% assign firstOther = false %}
        {% endunless %}{% endfor %}
      </div>
    </div>
  {% endif %}
</div>

{% render 'title_bar', meta: meta %}
