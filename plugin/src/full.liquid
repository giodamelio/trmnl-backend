{% comment %} World Cup — full view. Composes the partials defined in shared.liquid:
  today's games down the left, the stacked right-hand sections, then the title bar.
  Each section partial guards its own emptiness, so absent data renders nothing. {% endcomment %}
<div class="layout">

  {% if meta.todayCount > 0 %}{% render 'today_column', matches: matches, current: current %}{% endif %}

  {% comment %} Right side: stacked sections, each led by a title + rule header {% endcomment %}
  <div class="columns">
    <div class="column" style="justify-content: flex-start; gap: 11px;">
      {% render 'tomorrow_section', tomorrow: tomorrow, meta: meta %}
      {% render 'standings_section', standings: standings %}
      {% render 'favorites_section', favorites: favorites %}
      {% render 'city_section', cityGames: cityGames, city: city %}
    </div>
  </div>

</div>

{% render 'title_bar', meta: meta %}
